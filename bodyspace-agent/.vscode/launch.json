{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Once",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["tsx", "src/orchestrator.ts", "--once"],
      "env": {
        "NODE_OPTIONS": "--inspect-brk=9229"
      },
      "console": "integratedTerminal",
      "autoAttachChildProcesses": true
    },
     {
      "type": "node",
      "request": "launch",
      "name": "Fresher watcher",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["tsx", "src/orchestrator.ts", "--agent", "fresha-watcher"],
      "env": {
        "NODE_OPTIONS": "--inspect-brk=9229"
      },
      "console": "integratedTerminal",
      "autoAttachChildProcesses": true
    }
  ]
}
