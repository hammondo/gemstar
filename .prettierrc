{
    "plugins": ["prettier-plugin-organize-imports", "prettier-plugin-tailwindcss"],
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": true,
    "tabWidth": 4,
    "printWidth": 120,
    "endOfLine": "auto",
    "bracketSpacing": true,
    "overrides": [
        {
            "files": "*.yaml|*.json|*.yml",
            "options": {
                "tabWidth": 2,
                "singleQuote": false
            }
        }
    ]
}
