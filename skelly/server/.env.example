PORT=3000
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=info
NODE_ENV=development

# BodySpace Marketing Agent — Environment Configuration

# === Anthropic ===
ANTHROPIC_API_KEY=your_anthropic_api_key_here
MOCK_ANTHROPIC=false

# === Replicate (for image generation) ===
REPLICATE_API_TOKEN=your_replicate_api_token_here

# === Fresha Login (for automated CSV download via Playwright) ===
# The agent will log into partners.fresha.com and export the appointments CSV automatically.
# If not set, export the CSV manually and upload via the dashboard instead.
FRESHA_EMAIL=admin@bodyspacerecoverystudio.com.au
FRESHA_PASSWORD=

# Set to 1 to watch the browser run (useful for debugging login issues)
PLAYWRIGHT_HEADED=0

# === Postiz (Social Scheduler) ===
# Self-host: https://github.com/gitroomhq/postiz-app (docker-compose up)
# Or cloud: https://app.postiz.com
POSTIZ_API_URL=http://localhost:3000
POSTIZ_API_KEY=your_postiz_api_key

# === Notifications (owner approval alerts) ===
RESEND_API_KEY=your_resend_api_key
OWNER_EMAIL=owner@bodyspacerecoverystudio.com.au
OWNER_PHONE=+61466113438

# === Dashboard ===
DASHBOARD_PORT=3001
DASHBOARD_BASE_URL=http://localhost:5173
DASHBOARD_SESSION_SECRET=change-this-to-a-long-random-string

# === Meta (Facebook / Instagram) Analytics ===
# Create a Meta app at https://developers.facebook.com
# Requires: pages_read_engagement, pages_show_list, instagram_basic,
#           instagram_manage_insights, read_insights permissions
# Generate a long-lived Page Access Token from the Graph API Explorer
META_ACCESS_TOKEN=your-long-lived-page-access-token
META_PAGE_ID=your-facebook-page-id
META_IG_USER_ID=your-instagram-business-account-id
# META_API_VERSION=v21.0  # optional, defaults to v21.0

# === Microsoft Authentication (Azure App Registration) ===
# Register an app at https://portal.azure.com → Azure Active Directory → App registrations
# Add a redirect URI: http://localhost:3000/api/auth/callback (Web platform)
MS_CLIENT_ID=your-azure-app-client-id
MS_CLIENT_SECRET=your-azure-app-client-secret
MS_TENANT_ID=your-azure-tenant-id
MS_REDIRECT_URI=http://localhost:3000/api/auth/callback

# === Agent Schedule (cron, AWST = UTC+8) ===
TIMEZONE=Australia/Perth
FRESHA_WATCHER_CRON=0 8 * * *       # Daily 8am
MONITOR_AGENT_CRON=0 9 * * 1        # Monday 9am
CAMPAIGN_PLANNER_CRON=0 10 * * 1    # Monday 10am

# === Availability Thresholds ===
AVAILABILITY_PUSH_THRESHOLD=8       # >= 8 free slots → PUSH marketing
AVAILABILITY_PAUSE_THRESHOLD=1      # <= 1 free slot  → PAUSE marketing
