{
  "name": "bodyspace-gemstar-server",
  "version": "1.0.0",
  "description": "Autonomous marketing agent for BodySpace Recovery Studio",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "node --inspect=9229 --enable-source-maps --env-file-if-exists=.env --import=tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "playwright:install": "playwright install chromium --with-deps",
    "start": "node --enable-source-maps --env-file-if-exists=.env dist/index.js",
    "setup": "tsx src/scripts/setup.ts",
    "lint": "tsc --noEmit"
  },
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@azure/msal-node": "^3.8.10",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^11.10.0",
    "better-sqlite3-session-store": "^0.1.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.30.0",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "js-yaml": "^4.1.0",
    "multer": "^2.1.1",
    "node-cron": "^3.0.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "playwright": "^1.44.0",
    "resend": "^3.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/js-yaml": "^4.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/node-cron": "^3.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
