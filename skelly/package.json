{
  "name": "skelly",
  "version": "1.0.0",
  "private": true,
  "description": "Skelly monorepo app scaffold",
  "scripts": {
    "dev": "concurrently -k -n SERVER,DASHBOARD -c cyan,yellow \"npm --prefix server run dev\" \"npm --prefix dashboard run dev\"",
    "dev:server": "npm --prefix server run dev",
    "dev:dashboard": "npm --prefix dashboard run dev",
    "build": "npm run build:server && npm run build:dashboard",
    "build:server": "npm --prefix server run build",
    "build:dashboard": "npm --prefix dashboard run build",
    "start": "npm --prefix server run start",
    "start:server": "npm --prefix server run start",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [
    "typescript",
    "express",
    "react",
    "vite"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "@types/better-sqlite3": "^7.6.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/js-yaml": "^4.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/node-cron": "^3.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}