{
  "name": "skelly",
  "version": "1.0.0",
  "private": true,
  "description": "Skelly monorepo app scaffold",
  "scripts": {
    "dev": "concurrently -k -n SERVER,CLIENT -c cyan,magenta \"npm --prefix server run dev\" \"npm --prefix client run dev\"",
    "dev:server": "npm --prefix server run dev",
    "dev:client": "npm --prefix client run dev",
    "build": "npm run build:server && npm run build:client",
    "build:server": "npm --prefix server run build",
    "build:client": "npm --prefix client run build",
    "start": "npm --prefix server run start",
    "start:server": "npm --prefix server run start"
  },
  "keywords": [
    "typescript",
    "express",
    "react",
    "vite"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}