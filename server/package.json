{
  "name": "bodyspace-gemstar-server",
  "version": "1.0.0",
  "description": "Autonomous marketing agent for BodySpace Recovery Studio",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "node --inspect=9229 --enable-source-maps --env-file-if-exists=.env --import=tsx src/index.ts",
    "dev:watch": "node --enable-source-maps --env-file-if-exists=.env --import=tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "playwright:install": "playwright install chromium --with-deps",
    "start": "node --enable-source-maps --env-file-if-exists=.env dist/index.js",
    "setup": "tsx src/scripts/setup.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "lint:watch": "tsc --noEmit --watch",
    "dump:openapi": "tsx src/scripts/dump-openapi.ts",
    "regen:client": "npm run dump:openapi && npm run gen:api --prefix ../dashboard"
  },
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@asteasolutions/zod-to-openapi": "^7.3.4",
    "@azure/msal-node": "^3.8.10",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "connect-pg-simple": "^10.0.0",
    "pg": "^8.13.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "js-yaml": "^4.1.0",
    "multer": "^2.1.1",
    "node-cron": "^3.0.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "playwright": "^1.44.0",
    "resend": "^3.0.0",
    "sharp": "^0.34.5",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/connect-pg-simple": "^7.0.0",
    "@types/pg": "^8.11.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/js-yaml": "^4.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/node-cron": "^3.0.0",
    "@types/sharp": "^0.31.1",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}